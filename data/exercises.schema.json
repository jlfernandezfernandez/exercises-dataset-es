{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/jlfernandezfernandez/exercises-dataset-es/blob/main/data/exercises.schema.json",
  "title": "Bilingual Exercise Dataset",
  "type": "array",
  "items": {
    "type": "object",
    "additionalProperties": false,
    "required": ["id", "name", "name_en", "name_es", "body_part", "equipment", "muscle_group", "secondary_muscles", "target", "instructions", "image", "gif_url"],
    "properties": {
      "id": {"type": "string", "pattern": "^[0-9]{4}$"},
      "name": {"type": "string", "minLength": 1, "description": "Spanish display name, retained for backwards compatibility."},
      "name_en": {"type": "string", "minLength": 1},
      "name_es": {"type": "string", "minLength": 1},
      "body_part": {"type": "string", "minLength": 1},
      "equipment": {"type": "string", "minLength": 1},
      "muscle_group": {"type": "string", "minLength": 1},
      "secondary_muscles": {"type": "array", "items": {"type": "string"}},
      "target": {"type": "string", "minLength": 1},
      "instructions": {
        "type": "object",
        "required": ["en", "es"],
        "additionalProperties": false,
        "properties": {"en": {"type": "string", "minLength": 1}, "es": {"type": "string", "minLength": 1}}
      },
      "image": {"type": "string", "pattern": "^images/.+\\.(jpg|jpeg|png)$"},
      "gif_url": {"type": "string", "pattern": "^videos/.+\\.gif$"}
    }
  }
}
